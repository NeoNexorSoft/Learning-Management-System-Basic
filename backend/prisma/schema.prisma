generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum CourseStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

enum ObjectiveType {
  OBJECTIVE
  REQUIREMENT
  TARGET_AUDIENCE
}

enum LessonType {
  VIDEO
  TEXT
  DOCUMENT
  QUIZ
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  DROPPED
}

enum SubmissionStatus {
  SUBMITTED
  GRADED
  RETURNED
}

enum TransactionStatus {
  INITIATED
  PENDING
  COMPLETED
  FAILED
  REJECTED
}

enum TransactionType {
  PURCHASE
  DEPOSIT
  REFUND
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id             String   @id @default(uuid())
  name           String
  username       String   @unique
  email          String   @unique
  password_hash  String
  role           Role
  avatar         String?
  mobile         String?
  bio            String?
  country        String?
  balance        Decimal  @default(0) @db.Decimal(12, 2)
  email_verified Boolean  @default(false)
  is_banned      Boolean  @default(false)
  social_links   Json?
  payout_details Json?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  courses           Course[]
  enrollments       Enrollment[]
  submissions       Submission[]
  certificates      Certificate[]
  reviews           Review[]
  transactions      Transaction[]
  withdrawals       Withdrawal[]
  notifications     Notification[]    @relation("NotificationReceiver")
  sentNotifications Notification[]    @relation("NotificationSender")
  loginHistory      LoginHistory[]
  blogs             Blog[]            @relation("BlogAuthor")

  @@map("users")
}

model Category {
  id         String     @id @default(uuid())
  name       String
  slug       String     @unique
  parent_id  String?
  created_at DateTime   @default(now())

  parent     Category?  @relation("CategoryTree", fields: [parent_id], references: [id], onDelete: SetNull)
  children   Category[] @relation("CategoryTree")
  courses    Course[]

  @@map("categories")
}

model Course {
  id               String        @id @default(uuid())
  teacher_id       String
  category_id      String?
  title            String
  slug             String        @unique
  subtitle         String?
  description      String?
  language         String?       @default("English")
  level            CourseLevel?
  status           CourseStatus  @default(DRAFT)
  price            Decimal       @default(0) @db.Decimal(12, 2)
  discount_price   Decimal?      @db.Decimal(12, 2)
  discount_type    String?
  discount_ends_at DateTime?
  thumbnail        String?
  intro_video      String?
  duration         Int           @default(0)
  is_popular       Boolean       @default(false)
  welcome_message  String?
  congrats_message String?
  published_at     DateTime?
  created_at       DateTime      @default(now())
  updated_at       DateTime      @updatedAt

  teacher     User              @relation(fields: [teacher_id], references: [id])
  category    Category?         @relation(fields: [category_id], references: [id], onDelete: SetNull)
  objectives  CourseObjective[]
  sections    Section[]
  enrollments Enrollment[]
  certificates Certificate[]
  reviews     Review[]
  transactions Transaction[]

  @@map("courses")
}

model CourseObjective {
  id        String        @id @default(uuid())
  course_id String
  type      ObjectiveType
  content   String
  order     Int           @default(0)

  course    Course        @relation(fields: [course_id], references: [id], onDelete: Cascade)

  @@map("course_objectives")
}

model Section {
  id         String   @id @default(uuid())
  course_id  String
  title      String
  order      Int      @default(0)
  created_at DateTime @default(now())

  course   Course   @relation(fields: [course_id], references: [id], onDelete: Cascade)
  lessons  Lesson[]
  quizzes  Quiz[]

  @@map("sections")
}

model Lesson {
  id         String     @id @default(uuid())
  section_id String
  title      String
  type       LessonType
  content    String?
  video_url  String?
  file_url   String?
  duration   Int        @default(0)
  order      Int        @default(0)
  created_at DateTime   @default(now())

  section     Section          @relation(fields: [section_id], references: [id], onDelete: Cascade)
  progress    LessonProgress[]
  assignments Assignment[]

  @@map("lessons")
}

model Quiz {
  id         String   @id @default(uuid())
  section_id String
  title      String
  order      Int      @default(0)

  section   Section        @relation(fields: [section_id], references: [id], onDelete: Cascade)
  questions QuizQuestion[]

  @@map("quizzes")
}

model QuizQuestion {
  id             String @id @default(uuid())
  quiz_id        String
  question       String
  options        Json
  correct_answer String
  order          Int    @default(0)

  quiz Quiz @relation(fields: [quiz_id], references: [id], onDelete: Cascade)

  @@map("quiz_questions")
}

model Enrollment {
  id           String           @id @default(uuid())
  student_id   String
  course_id    String
  progress     Int              @default(0)
  status       EnrollmentStatus @default(ACTIVE)
  enrolled_at  DateTime         @default(now())
  completed_at DateTime?

  student        User             @relation(fields: [student_id], references: [id])
  course         Course           @relation(fields: [course_id], references: [id])
  lessonProgress LessonProgress[]
  certificate    Certificate?

  @@unique([student_id, course_id])
  @@map("enrollments")
}

model LessonProgress {
  id            String   @id @default(uuid())
  enrollment_id String
  lesson_id     String
  completed     Boolean  @default(false)
  watch_seconds Int      @default(0)
  updated_at    DateTime @updatedAt

  enrollment Enrollment @relation(fields: [enrollment_id], references: [id], onDelete: Cascade)
  lesson     Lesson     @relation(fields: [lesson_id], references: [id], onDelete: Cascade)

  @@unique([enrollment_id, lesson_id])
  @@map("lesson_progress")
}

model Assignment {
  id          String    @id @default(uuid())
  lesson_id   String
  title       String
  description String?
  due_date    DateTime?
  total_marks Int       @default(100)
  created_at  DateTime  @default(now())

  lesson      Lesson       @relation(fields: [lesson_id], references: [id], onDelete: Cascade)
  submissions Submission[]

  @@map("assignments")
}

model Submission {
  id            String           @id @default(uuid())
  assignment_id String
  student_id    String
  content       String?
  file_url      String?
  grade         Decimal?         @db.Decimal(5, 2)
  feedback      String?
  status        SubmissionStatus @default(SUBMITTED)
  submitted_at  DateTime         @default(now())

  assignment Assignment @relation(fields: [assignment_id], references: [id], onDelete: Cascade)
  student    User       @relation(fields: [student_id], references: [id])

  @@map("submissions")
}

model Certificate {
  id               String   @id @default(uuid())
  enrollment_id    String   @unique
  student_id       String
  course_id        String
  certificate_code String   @unique
  issued_at        DateTime @default(now())

  enrollment Enrollment @relation(fields: [enrollment_id], references: [id], onDelete: Cascade)
  student    User       @relation(fields: [student_id], references: [id])
  course     Course     @relation(fields: [course_id], references: [id])

  @@map("certificates")
}

model Review {
  id         String   @id @default(uuid())
  course_id  String
  student_id String
  rating     Int
  comment    String?
  created_at DateTime @default(now())

  course  Course @relation(fields: [course_id], references: [id], onDelete: Cascade)
  student User   @relation(fields: [student_id], references: [id])

  @@unique([course_id, student_id])
  @@map("reviews")
}

model Transaction {
  id               String            @id @default(uuid())
  user_id          String
  course_id        String?
  trx_id           String            @unique
  gateway          String
  amount           Decimal           @db.Decimal(12, 2)
  converted_amount Decimal           @db.Decimal(12, 2)
  status           TransactionStatus @default(INITIATED)
  type             TransactionType
  initiated_at     DateTime          @default(now())
  completed_at     DateTime?

  user   User    @relation(fields: [user_id], references: [id])
  course Course? @relation(fields: [course_id], references: [id])

  @@map("transactions")
}

model Withdrawal {
  id             String           @id @default(uuid())
  teacher_id     String
  amount         Decimal          @db.Decimal(12, 2)
  method         String
  payout_details Json
  status         WithdrawalStatus @default(PENDING)
  requested_at   DateTime         @default(now())
  processed_at   DateTime?

  teacher User @relation(fields: [teacher_id], references: [id])

  @@map("withdrawals")
}

model Coupon {
  id            String       @id @default(uuid())
  name          String
  code          String       @unique
  discount_type DiscountType
  value         Float
  is_active     Boolean      @default(true)
  expires_at    DateTime
  created_at    DateTime     @default(now())
  updated_at    DateTime     @updatedAt

  @@map("coupons")
}

model Notification {
  id         String   @id @default(uuid())
  user_id    String
  sender_id  String?
  title      String
  message    String
  is_read    Boolean  @default(false)
  created_at DateTime @default(now())

  user   User  @relation("NotificationReceiver", fields: [user_id], references: [id], onDelete: Cascade)
  sender User? @relation("NotificationSender", fields: [sender_id], references: [id])

  @@map("notifications")
}

model LoginHistory {
  id         String   @id @default(uuid())
  user_id    String
  ip_address String?
  location   String?
  browser    String?
  os         String?
  logged_at  DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("login_history")
}

model SystemSetting {
  id         String   @id @default(uuid())
  key        String   @unique
  value      String
  group      String
  updated_at DateTime @updatedAt

  @@map("system_settings")
}

model Blog {
  id               String   @id @default(uuid())
  slug             String   @unique
  title            String
  excerpt          String
  content          String   @db.Text
  featuredImageUrl String
  publishedAt      DateTime @default(now())
  updatedAt        DateTime @updatedAt
  readTimeMinutes  Int?
  category         String?
  tags             String[]
  authorId         String
  author           User     @relation("BlogAuthor", fields: [authorId], references: [id])

  @@index([slug])
  @@index([authorId])
  @@map("blogs")
}