generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum CourseStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

enum ObjectiveType {
  OBJECTIVE
  REQUIREMENT
  TARGET_AUDIENCE
}

enum LessonType {
  VIDEO
  TEXT
  DOCUMENT
  QUIZ
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  DROPPED
}

enum SubmissionStatus {
  SUBMITTED
  GRADED
  RETURNED
}

enum TransactionStatus {
  INITIATED
  PENDING
  COMPLETED
  FAILED
  REJECTED
}

enum TransactionType {
  PURCHASE
  DEPOSIT
  REFUND
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum AssignmentTarget {
  COURSE
  ALL_ENROLLED
}

enum AssignmentStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum WeaknessLevel {
  LOW
  MEDIUM
  HIGH
}

enum RoutinePlanStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum RoutineTaskStatus {
  PENDING
  UPCOMING
  COMPLETED
  MISSED
  CANCELLED
}

enum RoutineTaskType {
  READING
  PRACTICE
  REVISION
  TEST
  ASSIGNMENT
  OTHER
}

enum TrackerRecommendationPriority {
  LOW
  MEDIUM
  HIGH
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id             String   @id @default(uuid())
  name           String
  username       String   @unique
  email          String   @unique
  password_hash  String
  role           Role
  avatar         String?
  mobile         String?
  bio            String?
  country        String?
  balance        Decimal  @default(0) @db.Decimal(12, 2)
  email_verified Boolean  @default(false)
  is_banned      Boolean  @default(false)
  social_links   Json?
  payout_details Json?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  courses           Course[]
  enrollments       Enrollment[]
  submissions       Submission[]
  certificates      Certificate[]
  reviews           Review[]
  transactions      Transaction[]
  withdrawals       Withdrawal[]
  notifications     Notification[] @relation("NotificationReceiver")
  sentNotifications Notification[] @relation("NotificationSender")
  loginHistory      LoginHistory[]
  quizAttempts      QuizAttempt[]
  blogs             Blog[]            @relation("BlogAuthor")
  questionBank      QuestionBank[]
  simulations       Simulation[]      @relation("createdBy")
  assignments       Assignment[]

  studentWeaknesses              StudentWeakness[]       @relation("StudentWeaknessStudent")
  identifiedStudentWeaknesses    StudentWeakness[]       @relation("StudentWeaknessIdentifier")
  routinePlans                   RoutinePlan[]          @relation("RoutinePlanStudent")
  createdRoutinePlans            RoutinePlan[]          @relation("RoutinePlanCreator")
  routineTasks                   RoutineTask[]          @relation("RoutineTaskStudent")
  createdRoutineTasks            RoutineTask[]          @relation("RoutineTaskCreator")
  routineTaskLogs                RoutineTaskLog[]       @relation("RoutineTaskLogStudent")
  trackerRecommendations         TrackerRecommendation[] @relation("TrackerRecommendationStudent")
  createdTrackerRecommendations  TrackerRecommendation[] @relation("TrackerRecommendationCreator")
  receivedTrackerFeedbacks       TrackerFeedback[]      @relation("TrackerFeedbackStudent")
  givenTrackerFeedbacks          TrackerFeedback[]      @relation("TrackerFeedbackTeacher")

  @@map("users")
}

model Category {
  id         String   @id @default(uuid())
  name       String
  slug       String   @unique
  parent_id  String?
  created_at DateTime @default(now())

  parent   Category?  @relation("CategoryTree", fields: [parent_id], references: [id], onDelete: SetNull)
  children Category[] @relation("CategoryTree")
  courses  Course[]

  @@map("categories")
}

model Course {
  id               String       @id @default(uuid())
  teacher_id       String
  category_id      String?
  title            String
  slug             String       @unique
  subtitle         String?
  description      String?
  language         String?      @default("English")
  level            CourseLevel?
  status           CourseStatus @default(DRAFT)
  price            Decimal      @default(0) @db.Decimal(12, 2)
  discount_price   Decimal?     @db.Decimal(12, 2)
  discount_type    String?
  discount_ends_at DateTime?
  thumbnail        String?
  intro_video      String?
  duration         Int          @default(0)
  is_popular       Boolean      @default(false)
  welcome_message  String?
  congrats_message String?
  published_at     DateTime?
  created_at       DateTime     @default(now())
  updated_at       DateTime     @updatedAt

  teacher      User              @relation(fields: [teacher_id], references: [id])
  category     Category?         @relation(fields: [category_id], references: [id], onDelete: SetNull)
  objectives   CourseObjective[]
  sections     Section[]
  enrollments  Enrollment[]
  certificates Certificate[]
  reviews      Review[]
  transactions Transaction[]
  assignments  Assignment[]

  @@map("courses")
}

model CourseObjective {
  id        String        @id @default(uuid())
  course_id String
  type      ObjectiveType
  content   String
  order     Int           @default(0)

  course Course @relation(fields: [course_id], references: [id], onDelete: Cascade)

  @@map("course_objectives")
}

model Section {
  id         String   @id @default(uuid())
  course_id  String
  title      String
  order      Int      @default(0)
  created_at DateTime @default(now())

  course  Course   @relation(fields: [course_id], references: [id], onDelete: Cascade)
  lessons Lesson[]
  quizzes Quiz[]

  @@map("sections")
}

model Lesson {
  id         String     @id @default(uuid())
  section_id String
  title      String
  type       LessonType
  content    String?
  video_urls String[]
  file_urls  String[]
  duration   Int        @default(0)
  order      Int        @default(0)
  created_at DateTime   @default(now())

  section       Section          @relation(fields: [section_id], references: [id], onDelete: Cascade)
  progress      LessonProgress[]
  assignments   Assignment[]
  lessonQuizzes LessonQuiz[]

  @@map("lessons")
}

model Quiz {
  id         String @id @default(uuid())
  section_id String
  title      String
  order      Int    @default(0)

  section   Section        @relation(fields: [section_id], references: [id], onDelete: Cascade)
  questions QuizQuestion[]

  @@map("quizzes")
}

model QuizQuestion {
  id             String @id @default(uuid())
  quiz_id        String
  question       String
  options        Json
  correct_answer String
  order          Int    @default(0)

  quiz Quiz @relation(fields: [quiz_id], references: [id], onDelete: Cascade)

  @@map("quiz_questions")
}

model Enrollment {
  id           String           @id @default(uuid())
  student_id   String
  course_id    String
  progress     Int              @default(0)
  status       EnrollmentStatus @default(ACTIVE)
  enrolled_at  DateTime         @default(now())
  completed_at DateTime?

  student        User             @relation(fields: [student_id], references: [id])
  course         Course           @relation(fields: [course_id], references: [id], onDelete: Cascade)
  lessonProgress LessonProgress[]
  certificate    Certificate?

  @@unique([student_id, course_id])
  @@map("enrollments")
}

model LessonProgress {
  id            String   @id @default(uuid())
  enrollment_id String
  lesson_id     String
  completed     Boolean  @default(false)
  watch_seconds Int      @default(0)
  updated_at    DateTime @updatedAt

  enrollment Enrollment @relation(fields: [enrollment_id], references: [id], onDelete: Cascade)
  lesson     Lesson     @relation(fields: [lesson_id], references: [id], onDelete: Cascade)

  @@unique([enrollment_id, lesson_id])
  @@map("lesson_progress")
}

model Assignment {
  id             String           @id @default(uuid())
  teacher_id     String
  course_id      String?
  lesson_id      String?
  title          String
  description    String?
  file_url       String?
  target         AssignmentTarget @default(COURSE)
  status         AssignmentStatus @default(PENDING_APPROVAL)
  due_date       DateTime
  total_marks    Int              @default(100)
  score_released Boolean          @default(false)
  is_deleted     Boolean          @default(false)
  created_at     DateTime         @default(now())
  updated_at     DateTime         @updatedAt

  teacher     User         @relation(fields: [teacher_id], references: [id])
  course      Course?      @relation(fields: [course_id], references: [id], onDelete: SetNull)
  lesson      Lesson?      @relation(fields: [lesson_id], references: [id], onDelete: SetNull)
  submissions Submission[]

  @@map("assignments")
}

model Submission {
  id            String           @id @default(uuid())
  assignment_id String
  student_id    String
  content       String?
  file_url      String?
  grade         Decimal?         @db.Decimal(5, 2)
  feedback      String?
  status        SubmissionStatus @default(SUBMITTED)
  submitted_at  DateTime         @default(now())
  updated_at    DateTime         @updatedAt
  deleted_at    DateTime?

  assignment Assignment @relation(fields: [assignment_id], references: [id], onDelete: Cascade)
  student    User       @relation(fields: [student_id], references: [id])

  @@unique([assignment_id, student_id])
  @@map("submissions")
}

model Certificate {
  id               String   @id @default(uuid())
  enrollment_id    String   @unique
  student_id       String
  course_id        String
  certificate_code String   @unique
  issued_at        DateTime @default(now())

  enrollment Enrollment @relation(fields: [enrollment_id], references: [id], onDelete: Cascade)
  student    User       @relation(fields: [student_id], references: [id])
  course     Course     @relation(fields: [course_id], references: [id], onDelete: Cascade)

  @@map("certificates")
}

model Review {
  id         String   @id @default(uuid())
  course_id  String
  student_id String
  rating     Int
  comment    String?
  created_at DateTime @default(now())

  course  Course @relation(fields: [course_id], references: [id], onDelete: Cascade)
  student User   @relation(fields: [student_id], references: [id])

  @@unique([course_id, student_id])
  @@map("reviews")
}

model Transaction {
  id               String            @id @default(uuid())
  user_id          String
  course_id        String?
  invoice_number   String            @unique
  trx_id           String?           @unique
  gateway          String
  amount           Decimal           @db.Decimal(12, 2)
  converted_amount Decimal?          @db.Decimal(12, 2)
  status           TransactionStatus @default(INITIATED)
  type             TransactionType
  payment_method   String?
  initiated_at     DateTime          @default(now())
  completed_at     DateTime?

  user   User    @relation(fields: [user_id], references: [id])
  course Course? @relation(fields: [course_id], references: [id], onDelete: SetNull)

  @@map("transactions")
}

model Withdrawal {
  id             String           @id @default(uuid())
  teacher_id     String
  amount         Decimal          @db.Decimal(12, 2)
  method         String
  payout_details Json
  status         WithdrawalStatus @default(PENDING)
  requested_at   DateTime         @default(now())
  processed_at   DateTime?

  teacher User @relation(fields: [teacher_id], references: [id])

  @@map("withdrawals")
}

model Coupon {
  id            String       @id @default(uuid())
  name          String
  code          String       @unique
  discount_type DiscountType
  value         Float
  is_active     Boolean      @default(true)
  expires_at    DateTime
  created_at    DateTime     @default(now())
  updated_at    DateTime     @updatedAt

  @@map("coupons")
}

model Notification {
  id         String   @id @default(uuid())
  user_id    String
  sender_id  String?
  title      String
  message    String
  is_read    Boolean  @default(false)
  created_at DateTime @default(now())

  user   User  @relation("NotificationReceiver", fields: [user_id], references: [id], onDelete: Cascade)
  sender User? @relation("NotificationSender", fields: [sender_id], references: [id])

  @@map("notifications")
}

model LoginHistory {
  id         String   @id @default(uuid())
  user_id    String
  ip_address String?
  location   String?
  browser    String?
  os         String?
  logged_at  DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("login_history")
}

model SystemSetting {
  id         String   @id @default(uuid())
  key        String   @unique
  value      String
  group      String
  updated_at DateTime @updatedAt

  @@map("system_settings")
}

model LessonQuiz {
  id            String    @id @default(uuid())
  lesson_id     String
  title         String
  order         Int       @default(0)
  timer_seconds Int?
  deadline      DateTime?
  created_at    DateTime  @default(now())

  lesson    Lesson               @relation(fields: [lesson_id], references: [id], onDelete: Cascade)
  questions LessonQuizQuestion[]
  attempts  QuizAttempt[]

  @@map("lesson_quizzes")
}

model LessonQuizQuestion {
  id             String @id @default(uuid())
  quiz_id        String
  type           String @default("MCQ")
  question       String
  options        Json
  correct_answer String
  order          Int    @default(0)

  quiz LessonQuiz @relation(fields: [quiz_id], references: [id], onDelete: Cascade)

  @@map("lesson_quiz_questions")
}

model QuizAttempt {
  id                 String    @id @default(uuid())
  quiz_id            String
  student_id         String
  answers            Json
  score              Decimal?  @db.Decimal(5, 2)
  feedback           String?
  graded             Boolean   @default(false)
  submitted_at       DateTime  @default(now())
  started_at         DateTime?
  time_taken_seconds Int?
  is_late            Boolean   @default(false)
  submitted          Boolean   @default(false)

  quiz    LessonQuiz @relation(fields: [quiz_id], references: [id], onDelete: Cascade)
  student User       @relation(fields: [student_id], references: [id])

  @@unique([quiz_id, student_id])
  @@map("quiz_attempts")
}

model Blog {
  id               String   @id @default(uuid())
  slug             String   @unique
  title            String
  excerpt          String
  content          String   @db.Text
  featuredImageUrl String
  publishedAt      DateTime @default(now())
  updatedAt        DateTime @updatedAt
  readTimeMinutes  Int?
  category         String?
  tags             String[]
  authorId         String
  author           User     @relation("BlogAuthor", fields: [authorId], references: [id])

  @@index([slug])
  @@index([authorId])
  @@map("blogs")
}

model QuestionBank {
  id              String   @id @default(uuid())
  teacher_id      String
  questionText    String
  questionTextEn  String?
  type            String
  difficulty      String   @default("medium")
  marks           Int      @default(1)
  options         String? // JSON stringified
  answer          String?
  answerBn        String?
  explanation     String?
  explanationBn   String?
  subject         String?
  topic           String?
  subtopic        String?
  hint            String?
  source          String   @default("ai")
  sourceReference String?
  needEvaluation  Boolean  @default(false)
  status          String   @default("draft")
  isPublished     Boolean  @default(false)
  hasFigure       Boolean  @default(false)
  hasFormula      Boolean  @default(false)
  bloomLevel      String?
  metadata        String? // JSON stringified
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  subjectId Int?
  topicId   Int?
  User      User?   @relation(fields: [userId], references: [id])
  userId    String?

  @@map("questions")
}

model Simulation {
  id          String   @id @default(uuid())
  title       String
  description String?  @db.Text
  subject     String   // e.g. "Physics", "Chemistry", "Biology", "Math"
  gradeLevel  String   // e.g. "Grade 9", "Grade 10", "University"
  provider    String?   // e.g. "PhET", "GeoGebra", "HHMI BioInteractive"
  simulationUrl String // The third-party URL that will be embedded in the iframe
  thumbnailUrl  String? // Optional preview image stored on Cloudinary
  isPublished Boolean  @default(false)

  createdById String
  createdBy   User   @relation("createdBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([subject])
  @@index([gradeLevel])
  @@index([isPublished])
  @@index([createdById])

  @@map("simulations")
}

model WeaknessCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  type        String?
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  studentWeaknesses      StudentWeakness[]
  routineTasks           RoutineTask[]
  trackerRecommendations TrackerRecommendation[]

  @@index([is_active])
  @@map("weakness_categories")
}

model StudentWeakness {
  id               String        @id @default(uuid())
  student_id       String
  category_id      String
  score            Int           @default(0)
  level            WeaknessLevel @default(LOW)
  note             String?       @db.Text
  identified_by_id String?
  created_at       DateTime      @default(now())
  updated_at       DateTime      @updatedAt

  student      User             @relation("StudentWeaknessStudent", fields: [student_id], references: [id], onDelete: Cascade)
  category     WeaknessCategory @relation(fields: [category_id], references: [id], onDelete: Cascade)
  identifiedBy User?            @relation("StudentWeaknessIdentifier", fields: [identified_by_id], references: [id], onDelete: SetNull)

  @@unique([student_id, category_id])
  @@index([student_id])
  @@index([category_id])
  @@index([level])
  @@map("student_weaknesses")
}

model RoutinePlan {
  id            String            @id @default(uuid())
  student_id    String
  title         String
  start_date    DateTime
  end_date      DateTime?
  status        RoutinePlanStatus @default(ACTIVE)
  created_by_id String?
  created_at    DateTime          @default(now())
  updated_at    DateTime          @updatedAt

  student   User          @relation("RoutinePlanStudent", fields: [student_id], references: [id], onDelete: Cascade)
  createdBy User?         @relation("RoutinePlanCreator", fields: [created_by_id], references: [id], onDelete: SetNull)
  tasks     RoutineTask[]

  @@index([student_id])
  @@index([status])
  @@index([start_date])
  @@map("routine_plans")
}

model RoutineTask {
  id               String            @id @default(uuid())
  routine_plan_id  String?
  student_id       String
  category_id      String?
  subject          String
  topic            String?
  task_type        RoutineTaskType   @default(READING)
  date             DateTime
  start_time       DateTime?
  end_time         DateTime?
  duration_minutes Int?
  status           RoutineTaskStatus @default(UPCOMING)
  note             String?           @db.Text
  created_by_id    String?
  created_at       DateTime          @default(now())
  updated_at       DateTime          @updatedAt

  routinePlan RoutinePlan?     @relation(fields: [routine_plan_id], references: [id], onDelete: SetNull)
  student     User             @relation("RoutineTaskStudent", fields: [student_id], references: [id], onDelete: Cascade)
  category    WeaknessCategory? @relation(fields: [category_id], references: [id], onDelete: SetNull)
  createdBy   User?            @relation("RoutineTaskCreator", fields: [created_by_id], references: [id], onDelete: SetNull)
  logs        RoutineTaskLog[]

  @@index([student_id])
  @@index([routine_plan_id])
  @@index([category_id])
  @@index([date])
  @@index([status])
  @@map("routine_tasks")
}

model RoutineTaskLog {
  id              String            @id @default(uuid())
  routine_task_id String
  student_id      String
  status          RoutineTaskStatus
  completed_at    DateTime?
  note            String?           @db.Text
  created_at      DateTime          @default(now())

  routineTask RoutineTask @relation(fields: [routine_task_id], references: [id], onDelete: Cascade)
  student     User        @relation("RoutineTaskLogStudent", fields: [student_id], references: [id], onDelete: Cascade)

  @@index([routine_task_id])
  @@index([student_id])
  @@index([status])
  @@map("routine_task_logs")
}

model TrackerRecommendation {
  id              String                        @id @default(uuid())
  student_id      String
  category_id     String?
  title           String
  description     String?                       @db.Text
  priority        TrackerRecommendationPriority @default(MEDIUM)
  action_label    String?
  resource_url    String?
  is_active       Boolean                       @default(true)
  created_by_id   String?
  created_at      DateTime                      @default(now())
  updated_at      DateTime                      @updatedAt

  student   User              @relation("TrackerRecommendationStudent", fields: [student_id], references: [id], onDelete: Cascade)
  category  WeaknessCategory? @relation(fields: [category_id], references: [id], onDelete: SetNull)
  createdBy User?             @relation("TrackerRecommendationCreator", fields: [created_by_id], references: [id], onDelete: SetNull)

  @@index([student_id])
  @@index([category_id])
  @@index([priority])
  @@index([is_active])
  @@map("tracker_recommendations")
}

model TrackerFeedback {
  id         String   @id @default(uuid())
  student_id String
  teacher_id String?
  message    String   @db.Text
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  student User  @relation("TrackerFeedbackStudent", fields: [student_id], references: [id], onDelete: Cascade)
  teacher User? @relation("TrackerFeedbackTeacher", fields: [teacher_id], references: [id], onDelete: SetNull)

  @@index([student_id])
  @@index([teacher_id])
  @@map("tracker_feedbacks")
}

